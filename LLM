import requests
import subprocess
import time
import sys
import os
from openai import OpenAI

# 🔹 Start server
subprocess.Popen(["uvicorn", "server.app:app", "--host", "0.0.0.0", "--port", "8000"])
time.sleep(3)

BASE_URL = "http://127.0.0.1:8000"

# 🔹 Use injected proxy
client = OpenAI(
    base_url=os.environ.get("API_BASE_URL"),
    api_key=os.environ.get("API_KEY")
)

def reset():
    return requests.post(f"{BASE_URL}/reset").json()

def step(action):
    return requests.post(f"{BASE_URL}/step", json=action).json()


def get_action_from_llm(obs):
    prompt = f"""
    You are a task manager AI.
    Current state: {obs}
    Decide next action in JSON format:
    {{"cmd": "add/done", "task": "...", "id": number}}
    """

    response = client.chat.completions.create(
        model="gpt-4o-mini",  # works with proxy
        messages=[{"role": "user", "content": prompt}]
    )

    content = response.choices[0].message.content

    try:
        return eval(content)  # simple parse
    except:
        return {"cmd": "add", "task": "fallback"}


if __name__ == "__main__":
    task_name = "task-manager"

    print(f"[START] task={task_name}")
    sys.stdout.flush()

    obs = reset()

    total_reward = 0
    steps = 0

    for _ in range(5):
        action = get_action_from_llm(obs)

        result = step(action)

        reward = result.get("reward", 0)
        total_reward += reward
        steps += 1

        print(f"[STEP] step={steps} reward={reward}")
        sys.stdout.flush()

        obs = result

        if result.get("done"):
            break

    score = total_reward / max(steps, 1)

    print(f"[END] task={task_name} score={score} steps={steps}")
    sys.stdout.flush()
